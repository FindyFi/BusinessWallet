FROM node:20

WORKDIR /app

# Build tools needed to compile native Askar bindings if prebuilt binaries
# are unavailable for the current platform.
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev"]
